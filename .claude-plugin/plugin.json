{
  "name": "dev-stacks",
  "version": "1.0.0",
  "description": "Zero-friction AI development assistant. Intent routing, adaptive workflows, agent teams, pattern learning, and safety guards.",
  "author": {
    "name": "1827mk",
    "url": "https://github.com/1827mk/dev-stacks"
  },
  "license": "MIT",
  "keywords": ["orchestrator", "intent-routing", "agents", "workflows", "pattern-learning", "safety-guards", "thai-english"],
  "hooks": {
    "SessionStart": {
      "type": "prompt",
      "path": "${CLAUDE_PLUGIN_ROOT}/hooks/SessionStart.md"
    },
    "UserPromptSubmit": {
      "type": "prompt",
      "path": "${CLAUDE_PLUGIN_ROOT}/hooks/UserPromptSubmit.md"
    },
    "PreToolUse": {
      "type": "prompt",
      "path": "${CLAUDE_PLUGIN_ROOT}/hooks/PreToolUse.md"
    },
    "PostToolUse": {
      "type": "prompt",
      "path": "${CLAUDE_PLUGIN_ROOT}/hooks/PostToolUse.md"
    },
    "Stop": {
      "type": "prompt",
      "path": "${CLAUDE_PLUGIN_ROOT}/hooks/Stop.md"
    },
    "PreCompact": {
      "type": "prompt",
      "path": "${CLAUDE_PLUGIN_ROOT}/hooks/PreCompact.md"
    }
  }
}
