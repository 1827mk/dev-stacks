{
  "version": "1.0.0",
  "rules": [
    {
      "id": "rm-root",
      "pattern": "rm -rf /",
      "action": "BLOCK",
      "reason": "Destructive command - removes entire filesystem",
      "severity": "CRITICAL"
    },
    {
      "id": "rm-home",
      "pattern": "rm -rf ~",
      "action": "BLOCK",
      "reason": "Destructive command - removes home directory",
      "severity": "CRITICAL"
    },
    {
      "id": "rm-wildcard",
      "pattern": "rm -rf /*",
      "action": "BLOCK",
      "reason": "Destructive command - removes all files",
      "severity": "CRITICAL"
    },
    {
      "id": "mkfs",
      "pattern": "mkfs",
      "action": "BLOCK",
      "reason": "Destructive command - formats filesystem",
      "severity": "CRITICAL"
    },
    {
      "id": "dd-disk",
      "pattern": "dd if=",
      "action": "BLOCK",
      "reason": "Destructive command - disk operations",
      "severity": "CRITICAL"
    },
    {
      "id": "drop-database",
      "pattern": "DROP DATABASE",
      "action": "BLOCK",
      "reason": "Destructive SQL command",
      "severity": "CRITICAL"
    },
    {
      "id": "drop-table",
      "pattern": "DROP TABLE",
      "action": "BLOCK",
      "reason": "Destructive SQL command",
      "severity": "CRITICAL"
    },
    {
      "id": "truncate",
      "pattern": "TRUNCATE",
      "action": "CONFIRM",
      "reason": "Destructive SQL command",
      "severity": "HIGH"
    },
    {
      "id": "delete-all",
      "pattern": "DELETE FROM",
      "action": "CONFIRM",
      "reason": "Potentially destructive SQL command",
      "severity": "MEDIUM"
    },
    {
      "id": "chmod-777",
      "pattern": "chmod -R 777",
      "action": "CONFIRM",
      "reason": "Insecure permission change",
      "severity": "MEDIUM"
    }
  ]
}
